# Railway environment variables for DocuSeal
# Set these in the Railway dashboard for the DocuSeal app service.

# Provided automatically when you link Railway Postgres and Redis services
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...

# Required
HOST=enroll.yourdomain.com   # or the Railway generated domain while testing
SECRET_KEY_BASE=518115953f63621aec15110a619bde97bb0c33605e6ba7c7d79ece44524bb7d6ad2f12fc113cdbd9c1b8fa487984103620eef57a4be81cdca7d17857e2dce8fc

# Optional tuning
RAILS_LOG_LEVEL=info

# If you want to use a different port inside (Railway handles external)
# PORT=3000
